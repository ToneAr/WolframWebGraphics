Notebook[{

Cell[CellGroupData[{
Cell["Building Pages and Dashboards with WebGraphics", "Title",
 CellChangeTimes->{{3.990151736857937*^9, 3.990151753165235*^9}},
 CellID->874003867,ExpressionUUID->"6acdfade-2835-48e9-a1e2-bd7d7543e4d4"],

Cell["\<\
WebGraphics are designed to be portable and stand-alone, inlining all scripts \
and styles they need. However, when multiple WebGraphics are used on a single \
page, a single inline instance of the library and styles can save on the page \
file size, leading to better responsiveness.\
\>", "Text",
 CellChangeTimes->{{3.990151689660935*^9, 3.990151921411422*^9}, {
  3.990152204737762*^9, 3.9901522446761847`*^9}},
 CellID->2010888846,ExpressionUUID->"a2cb404e-759a-41df-b2ef-c474b56149ce"],

Cell[BoxData[GridBox[{
   {"XXXX", Cell[
    "XXXX", "TableText",ExpressionUUID->
     "b94e6906-d3db-48e5-b77d-6a233bc1b5b5"]},
   {"XXXX", Cell[
    "XXXX", "TableText",ExpressionUUID->
     "3df07494-bef8-48a8-936c-9f5e3877657c"]},
   {"XXXX", Cell[
    "XXXX", "TableText",ExpressionUUID->
     "72cf5372-24dc-4af6-be4e-23ecfed889dd"]}
  }]], "DefinitionBox",
 CellID->713277456,ExpressionUUID->"be60d83b-f748-4768-ace4-e49c6f7c5670"],

Cell["XXXX.", "Caption",
 CellID->1360798979,ExpressionUUID->"acc8fa7b-16f4-43d4-8969-fc2979b2738d"],

Cell[CellGroupData[{

Cell["Multi-Graphics Single Web Element", "Section",
 CellChangeTimes->{{3.990152258275936*^9, 3.990152276267247*^9}, {
  3.9901524275335712`*^9, 3.990152443345208*^9}},
 CellID->360616084,ExpressionUUID->"ca1ad59f-d8bf-49b6-880e-c1d3297c0590"],

Cell["\<\
By default, WebGraphics that serialize multiple graphics, including with \
Inset and Show, will automatically only include the runtime library and \
styles only once.\
\>", "Text",
 CellID->815714120,ExpressionUUID->"31bb6e3f-4efc-466e-a391-baada2e7693d"],

Cell[CellGroupData[{

Cell["\<\
Even if multiple interactive elements are used within the same WebGraphic, \
only a single instance of the runtime script and style will be inlined:\
\>", "MathCaption",
 CellChangeTimes->{{3.990151586173532*^9, 3.990151588436767*^9}, {
   3.990152282911744*^9, 3.990152282983045*^9}, 3.9901523761018333`*^9, {
   3.990152410605566*^9, 3.990152412260754*^9}, {3.990152545129881*^9, 
   3.9901525723774147`*^9}},
 CellID->1942031149,ExpressionUUID->"58096ece-6ca7-4db7-bf32-d0d66288c2f6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ToWebGraphics", "[", " ", "\[IndentingNewLine]", 
    RowBox[{"Graphics", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Tooltip", "[", 
        RowBox[{
         RowBox[{"Disk", "[", "]"}], ",", " ", "\"\<Disk\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Inset", "@", "\[IndentingNewLine]", 
        RowBox[{"Graphics", "[", 
         RowBox[{"{", " ", 
          RowBox[{"Tooltip", "[", 
           RowBox[{
            RowBox[{"Circle", "[", "]"}], ",", " ", "\"\<Circle\>\""}], "]"}],
           "}"}], "]"}]}]}], "\[IndentingNewLine]", "}"}], "]"}], 
    "\[IndentingNewLine]", "]"}], "//", 
   RowBox[{"StringCases", "[", "\[IndentingNewLine]", 
    RowBox[{"\"\<<style>\>\"", " ", "|", " ", "\"\<<script>\>\""}], 
    "\[IndentingNewLine]", "]"}]}], "//", "Counts", " "}]], "Input",
 CellChangeTimes->{{3.990152378131564*^9, 3.990152407243375*^9}, {
  3.990152456866374*^9, 3.99015253265598*^9}, {3.990152726296872*^9, 
  3.9901527322746477`*^9}, {3.9901528616299973`*^9, 3.990152881806919*^9}},
 CellLabel->"In[3]:=",
 CellID->1860281072,ExpressionUUID->"f7083c96-6396-4b35-af09-d5c2ef7886ad"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"<style>\"\>", "\[Rule]", "1"}], ",", 
   RowBox[{"\<\"<script>\"\>", "\[Rule]", "1"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{
  3.9901524009106617`*^9, {3.990152498206658*^9, 3.990152533174268*^9}, 
   3.990152733690877*^9, {3.9901528650199003`*^9, 3.990152882256373*^9}, 
   3.990366293653956*^9},
 CellLabel->"Out[3]=",
 CellID->753157928,ExpressionUUID->"5171ecfa-02e1-4e26-9172-81c1709e2af0"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
However, we often need generate WebGraphics separately, at which point we run \
into the issue of the multiple instances of the runtime resources being \
inlined: \
\>", "MathCaption",
 CellChangeTimes->{{3.990151586173532*^9, 3.990151588436767*^9}, {
   3.990152282911744*^9, 3.990152282983045*^9}, 3.9901523761018333`*^9, {
   3.990152410605566*^9, 3.990152412260754*^9}, {3.990152545129881*^9, 
   3.9901525723774147`*^9}, {3.990152608996687*^9, 3.990152693275676*^9}},
 CellID->1025866719,ExpressionUUID->"daa558e7-28be-4499-bab7-1fcc131cd906"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"StringJoin", "[", "\[IndentingNewLine]", 
     RowBox[{"ToWebGraphics", "/@", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Graphics", "[", 
         RowBox[{"{", 
          RowBox[{"Tooltip", "[", 
           RowBox[{
            RowBox[{"Disk", "[", "]"}], ",", " ", "\"\<Disk\>\""}], "]"}], 
          "}"}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Graphics", "[", 
         RowBox[{"{", " ", 
          RowBox[{"Tooltip", "[", 
           RowBox[{
            RowBox[{"Circle", "[", "]"}], ",", " ", "\"\<Circle\>\""}], "]"}],
           "}"}], "]"}]}], "\[IndentingNewLine]", "}"}]}], 
     "\[IndentingNewLine]", "]"}], "//", 
    RowBox[{"StringCases", "[", "\[IndentingNewLine]", 
     RowBox[{"\"\<<style>\>\"", " ", "|", " ", "\"\<<script>\>\""}], 
     "\[IndentingNewLine]", "]"}]}], "//", "Counts"}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.9901527009015837`*^9, 3.990152764369185*^9}, {
  3.990152869049062*^9, 3.990152888627556*^9}},
 CellLabel->"In[5]:=",
 CellID->1616376798,ExpressionUUID->"065fe056-29bb-4c61-8de6-f1d6ac9893ab"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"<style>\"\>", "\[Rule]", "2"}], ",", 
   RowBox[{"\<\"<script>\"\>", "\[Rule]", "2"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{{3.9901527489646397`*^9, 3.990152764984321*^9}, {
   3.990152873715596*^9, 3.990152889256093*^9}, 3.990153666258301*^9, 
   3.990366301645844*^9},
 CellLabel->"Out[5]=",
 CellID->1719779641,ExpressionUUID->"cff8dd07-764e-49fa-858c-2fdada65c63a"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Multiple WebGraphics on a Single Page", "Section",
 CellChangeTimes->{{3.990152258275936*^9, 3.990152276267247*^9}, {
  3.9901524275335712`*^9, 3.990152443345208*^9}, {3.990152911694028*^9, 
  3.990152933789352*^9}},
 CellID->1413231748,ExpressionUUID->"1e062faf-99ac-45c3-984d-40b50f7f3141"],

Cell["\<\
The WebGraphics exposes various helpers and Options to allow manual inlining \
of the runtime resources.\
\>", "Text",
 CellChangeTimes->{{3.990152945992333*^9, 3.9901529818352623`*^9}},
 CellID->729549151,ExpressionUUID->"cf0f2b1f-7d53-47d1-9f0a-2e3831c1e077"],

Cell[CellGroupData[{

Cell["\<\
The \"IncludeRuntime\" Option can be used to disable the inclusion of the \
runtime resources:\
\>", "MathCaption",
 CellChangeTimes->{{3.990151586173532*^9, 3.990151588436767*^9}, {
   3.990152282911744*^9, 3.990152282983045*^9}, 3.9901523761018333`*^9, {
   3.990152410605566*^9, 3.990152412260754*^9}, {3.990152545129881*^9, 
   3.9901525723774147`*^9}, {3.990152608996687*^9, 3.990152693275676*^9}, {
   3.9901529891412687`*^9, 3.9901530609782457`*^9}, {3.9901534620624104`*^9, 
   3.990153473116312*^9}},
 CellID->600696254,ExpressionUUID->"a55b1e49-a1ba-4aee-8a67-a64e448b3969"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ToWebGraphics", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Graphics", "[", 
     RowBox[{"{", " ", 
      RowBox[{"Tooltip", "[", 
       RowBox[{
        RowBox[{"Disk", "[", "]"}], ",", " ", "\"\<Disk\>\""}], "]"}], " ", 
      "}"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<IncludeRuntime\>\"", " ", "->", " ", "False"}]}], 
   "\[IndentingNewLine]", "]"}], "//", 
  RowBox[{"StringCases", "[", "\[IndentingNewLine]", 
   RowBox[{"\"\<<style>\>\"", " ", "|", " ", "\"\<<script>\>\""}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.990152792507868*^9, 3.9901528147481003`*^9}, 
   3.990152987679627*^9, {3.990153065350371*^9, 3.990153076771771*^9}, {
   3.990153155482121*^9, 3.990153176466743*^9}, {3.990153220299973*^9, 
   3.9901532681417723`*^9}, {3.9901533446924143`*^9, 3.990153381147954*^9}, {
   3.990153443346674*^9, 3.990153476681786*^9}, {3.990153547848152*^9, 
   3.99015354831348*^9}, {3.9901536708743963`*^9, 3.9901536713988237`*^9}, {
   3.990153922973804*^9, 3.9901539284988937`*^9}},
 CellLabel->"In[6]:=",
 CellID->842028405,ExpressionUUID->"5995f772-e129-4b19-9137-6e9ee4756722"],

Cell[BoxData[
 RowBox[{"{", "}"}]], "Output",
 CellChangeTimes->{{3.990153667596092*^9, 3.9901536716277933`*^9}, {
   3.9901539239384813`*^9, 3.990153928728663*^9}, 3.990366302836844*^9},

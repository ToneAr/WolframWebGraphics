Cell[CellGroupData[{

Cell["\<\
The runtime can look for div elements using a specific attribute pattern, and \
handle the fetching and rendering of the WebGraphic from the API: \
\>", "MathCaption",
 CellChangeTimes->{{3.990151586173532*^9, 3.990151588436767*^9}, {
   3.990152282911744*^9, 3.990152282983045*^9}, 3.9901523761018333`*^9, {
   3.990152410605566*^9, 3.990152412260754*^9}, {3.990152545129881*^9, 
   3.9901525723774147`*^9}, {3.990152608996687*^9, 3.990152693275676*^9}, {
   3.9901529891412687`*^9, 3.9901530609782457`*^9}, {3.9901534620624104`*^9, 
   3.990153473116312*^9}, {3.990153937396216*^9, 3.990153977018464*^9}, {
   3.990165733682437*^9, 3.990165785742547*^9}, {3.9901659253126583`*^9, 
   3.990165940170278*^9}, {3.990166001395808*^9, 3.990166001889328*^9}, {
   3.990166479579617*^9, 3.990166517249303*^9}, {3.990166565540131*^9, 
   3.990166591520355*^9}, {3.9901666932443542`*^9, 3.99016674835666*^9}, {
   3.990371327614038*^9, 3.990371390481023*^9}},
 CellID->12773248,ExpressionUUID->"58295f2e-6fb8-4fbf-80ec-59a66fc5c8d7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "demoHtml", " ", "=", 
   " ", "\"\<\n<!DOCTYPE html>\n<html>\n\t<head>\n\t\t<title>Runtime \
Example</title>\n\t\t<script\n\t\t\ttype='module'\n\t\t\t\
src='./wgx-runtime/wgx-runtime.js'\n\t\t></script>\n\t</head>\n\t<body>\n\t\t\
<div\n\t\t\tid='some-plot-placehoder'\n\t\t\t\
data-wgx-ssr-endpoint='/api/plot'\n\t\t></div>\n\t\t<div\n\t\t\t\
id='some-parameterised-plot-placehoder'\n\t\t\t\
data-wgx-ssr-endpoint='/api/plot2'\n\t\t\tdata-wgx-ssr-params='f=Cos&xmax=20'\
\n\t\t></div>\n\t</body>\n</html>\n\>\""}], ";"}]], "Input",
 CellChangeTimes->{{3.990371957805332*^9, 3.990372105610572*^9}, {
  3.990372139190534*^9, 3.9903721559802647`*^9}, {3.990372394184799*^9, 
  3.9903723961715307`*^9}, {3.990372502279789*^9, 3.9903725027657547`*^9}, {
  3.990373627713572*^9, 3.990373631163685*^9}, {3.990374142504344*^9, 
  3.990374144590541*^9}, {3.990374885898992*^9, 3.9903748965692*^9}, {
  3.990375862166535*^9, 3.9903758629995604`*^9}, {3.990376495318665*^9, 
  3.990376513505357*^9}, {3.990376774309366*^9, 3.990376798072095*^9}},
 CellLabel->"In[142]:=",
 CellID->1570015268,ExpressionUUID->"28dd9ad3-cec0-43ba-9b3c-7e1cb97b4bbb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The runtime will use the data attributes in all wgx-ssr div placeholders to \
fetch and replace them with the HTML received from the API.\
\>", "Text",
 CellChangeTimes->{{3.990152945992333*^9, 3.9901529818352623`*^9}, {
  3.990166401013803*^9, 3.990166474006578*^9}, {3.990178533169507*^9, 
  3.9901786434905024`*^9}, {3.990178742545466*^9, 3.990178774070333*^9}, {
  3.9901857103967*^9, 3.990185768019227*^9}, {3.990371556229128*^9, 
  3.990371562074046*^9}, {3.9903716025427027`*^9, 3.9903716743899612`*^9}},
 CellID->359166804,ExpressionUUID->"6d6f50a3-f643-4561-8a0b-32238db03b57"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"disp", " ", "=", " ", 
   RowBox[{"URLDispatcher", "[", "\n", "\t", 
    RowBox[{"Join", "[", "\n", "\t\t", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{
         RowBox[{"\"\</\>\"", " ", "~~", " ", "EndOfString"}], " ", ":>", " ", 
         RowBox[{"ExportForm", "[", 
          RowBox[{"demoHtml", ",", " ", "\"\<HTML\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"\"\</api/plot\>\"", " ", "~~", "EndOfString"}], " ", ":>", 
         " ", "api"}], ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"\"\</api/plot2\>\"", " ", "~~", "EndOfString"}], " ", ":>", 
         " ", "api2"}]}], "\[IndentingNewLine]", "\t", "}"}], ",", "\n", "\t", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Serve", " ", "all", " ", "WGX", " ", "runtime", " ", "files"}], " ", 
       "*)"}], "\t", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{"f", ",", "\n", "\t\t\t", 
         RowBox[{
          RowBox[{"StringDelete", "[", 
           RowBox[{"f", ",", " ", "\"\</tmp\>\""}], "]"}], " ", ":>", " ", 
          RowBox[{"HTTPResponse", "[", "\n", "\t\t\t\t", 
           RowBox[{
            RowBox[{"ReadString", "[", "f", "]"}], ",", "\n", "\t\t\t\t", 
            RowBox[{"<|", "\[IndentingNewLine]", "\t\t", 
             RowBox[{"\"\<ContentType\>\"", " ", "->", " ", 
              RowBox[{
               RowBox[{"runtimeMime", "[", "f", "]"}], " ", "<>", 
               " ", "\"\<; charset=utf-8\>\""}]}], "\[IndentingNewLine]", 
             "\t\t", "|>"}]}], "\n", "\t\t\t", "]"}]}]}], "\n", "\t\t", "]"}],
        " ", "/@", " ", 
       RowBox[{"FileNames", "[", 
        RowBox[{"All", ",", " ", "dir"}], "]"}]}]}], "\n", "\t", "]"}], "\n", 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ld", "=", 
   RowBox[{
    RowBox[{"PacletSymbol", "[", 
     RowBox[{"\"\<ToneAr/LocalDeploy\>\"", ",", "\"\<LocalDeploy\>\""}], 
     "]"}], "[", "\[IndentingNewLine]", 
    RowBox[{"disp", ",", "\[IndentingNewLine]", "30000"}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Hyperlink", "[", 
  RowBox[{"ld", "[", "\"\<URL\>\"", "]"}], "]"}]}], "Input",
 CellChangeTimes->{
  3.990375014463172*^9, 3.990375868318515*^9, {3.990376325312023*^9, 
   3.990376370616523*^9}, {3.990376810266985*^9, 3.990376818172838*^9}},
 CellLabel->"In[143]:=",
 CellID->931731652,ExpressionUUID->"76e24429-7803-4ade-93e7-a4b6044c6a99"],


Cell["\<\
The example.html page now has everything needed to build a dynamic dashboard. \
There are various options for serving WebGraphics. \
\>", "Text",
 CellChangeTimes->{{3.990152945992333*^9, 3.9901529818352623`*^9}, {
  3.990166401013803*^9, 3.990166474006578*^9}, {3.990371266968103*^9, 
  3.990371267150395*^9}},
 CellID->1240048201,ExpressionUUID->"682cd73b-9202-4bcc-bc69-c05fc32327ed"],

Cell[CellGroupData[{

Cell["\<\
A server can also serve WebGraphics generated on demand as the page loads by \
using an APIFunction:\
\>", "MathCaption",
 CellChangeTimes->{{3.990151586173532*^9, 3.990151588436767*^9}, {
   3.990152282911744*^9, 3.990152282983045*^9}, 3.9901523761018333`*^9, {
   3.990152410605566*^9, 3.990152412260754*^9}, {3.990152545129881*^9, 
   3.9901525723774147`*^9}, {3.990152608996687*^9, 3.990152693275676*^9}, {
   3.9901529891412687`*^9, 3.9901530609782457`*^9}, {3.9901534620624104`*^9, 
   3.990153473116312*^9}, {3.990153937396216*^9, 3.990153977018464*^9}, {
   3.990165733682437*^9, 3.990165785742547*^9}, {3.9901659253126583`*^9, 
   3.990165940170278*^9}, {3.990166001395808*^9, 3.990166001889328*^9}, {
   3.990166479579617*^9, 3.990166517249303*^9}, {3.990166565540131*^9, 
   3.990166591520355*^9}},
 CellID->1821970401,ExpressionUUID->"99224e7b-fac5-48ae-8de2-eac72820d8d0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Deployed", " ", 
    RowBox[{
     RowBox[{"at", " ", "/", "api"}], "/", "plot"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"api", " ", "=", " ", "\[IndentingNewLine]", 
     RowBox[{"APIFunction", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ToWebGraphics", "[", " ", 
         RowBox[{
          RowBox[{"Plot", "[", 
           RowBox[{"x", ",", " ", 
            RowBox[{"{", 
             RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", " ", 
          RowBox[{"\"\<IncludeRuntime\>\"", " ", "->", " ", "False"}]}], " ", 
         "]"}], "&"}], ",", "\[IndentingNewLine]", "\"\<HTML\>\""}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"api2", " ", "=", " ", "\[IndentingNewLine]", 
     RowBox[{"APIFunction", "[", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"\"\<f\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<Sin\>\"", ",", " ", "\"\<Cos\>\"", ",", 
            " ", "\"\<Tan\>\""}], "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"\"\<xmax\>\"", " ", "->", " ", 
          RowBox[{"\"\<Number\>\"", " ", "->", " ", "10"}]}]}], 
        "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ToWebGraphics", "[", " ", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Plot", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ToExpression", "[", "#f", "]"}], "[", "x", "]"}], ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"x", ",", "0", ",", "#xmax"}], "}"}], ",", " ", 
            RowBox[{"{", "}"}]}], "]"}], ",", "\[IndentingNewLine]", " ", 
          RowBox[{"\"\<IncludeRuntime\>\"", " ", "->", " ", "False"}]}], 
         "\[IndentingNewLine]", "]"}], "&"}], ",", 
       "\[IndentingNewLine]", "\"\<HTML\>\""}], "\[IndentingNewLine]", 
      "]"}]}], ";"}]}]}]], "Input",

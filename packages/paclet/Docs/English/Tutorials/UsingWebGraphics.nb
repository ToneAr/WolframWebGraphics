   3.990153473116312*^9}, {3.990153937396216*^9, 3.990153977018464*^9}, {
   3.9903706022634907`*^9, 3.99037063395804*^9}, {3.9903709460140142`*^9, 
   3.990370947859413*^9}},
 CellID->1000736901,ExpressionUUID->"0463e84a-8ff0-4ca7-b1e1-7ab9d01f84ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dir", " ", "=", " ", 
  RowBox[{"CreateWebGraphicsRuntime", "[", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{"$TemporaryDirectory", ",", " ", "\"\<wgx-runtime\>\""}], "}"}], 
    "]"}], " ", "]"}]}]], "Input",
 CellChangeTimes->{{3.990370948978429*^9, 3.990370986544231*^9}, {

Cell[CellGroupData[{

Cell["\<\
When building the page, \"IncludeRuntime\" can be disabled and the runtime \
resources can either inlined manually or fetched from a hosting location:\
\>", "MathCaption",
 CellChangeTimes->{{3.990151586173532*^9, 3.990151588436767*^9}, {
   3.990152282911744*^9, 3.990152282983045*^9}, 3.9901523761018333`*^9, {
   3.990152410605566*^9, 3.990152412260754*^9}, {3.990152545129881*^9, 
   3.9901525723774147`*^9}, {3.990152608996687*^9, 3.990152693275676*^9}, {
   3.9901529891412687`*^9, 3.9901530609782457`*^9}, {3.9901534620624104`*^9, 
   3.990153473116312*^9}, {3.990153937396216*^9, 3.990153977018464*^9}, {
   3.990165733682437*^9, 3.990165785742547*^9}, {3.9901659253126583`*^9, 
   3.990165940170278*^9}, {3.990166001395808*^9, 3.990166001889328*^9}},
 CellID->414493608,ExpressionUUID->"e1d4f031-58b6-478e-b146-0dc798dd050d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "demoTemplate", " ", "=", 
   " ", "\"\<\n<!DOCTYPE html>\n<html>\n\t<head>\n\t\t<title>Runtime \
Example</title>\n\t\t<script\n\t\t\ttype='module'\n\t\t\t\
src='./wgx-runtime/wgx-runtime.js'\n\t\t></script>\n\t</head>\n\t<body>\n\t\t\
<wolfram:slot id='content' />\n\t</body>\n</html>\n\>\""}], ";"}]], "Input",
 CellChangeTimes->{{3.990371957805332*^9, 3.990372105610572*^9}, {
  3.990372139190534*^9, 3.9903721559802647`*^9}, {3.990372394184799*^9, 
  3.9903723961715307`*^9}, {3.990372502279789*^9, 3.9903725027657547`*^9}, {
  3.990373627713572*^9, 3.990373631163685*^9}, {3.990374142504344*^9, 
  3.990374144590541*^9}},
 CellLabel->"In[146]:=",
 CellID->1316237518,ExpressionUUID->"1d4b6dc5-9a62-4429-81aa-4e478b28f60a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The simplest way to add a WebGraphic is to directly inline it which makes the \
HTML completely portable and static and can contain any number of WebGraphics:\
\>", "MathCaption",
 CellChangeTimes->{{3.990151586173532*^9, 3.990151588436767*^9}, {
   3.990152282911744*^9, 3.990152282983045*^9}, 3.9901523761018333`*^9, {
   3.990152410605566*^9, 3.990152412260754*^9}, {3.990152545129881*^9, 
   3.9901525723774147`*^9}, {3.990152608996687*^9, 3.990152693275676*^9}, {
   3.9901529891412687`*^9, 3.9901530609782457`*^9}, {3.9901534620624104`*^9, 
   3.990153473116312*^9}, {3.990153937396216*^9, 3.990153977018464*^9}, {
   3.990165733682437*^9, 3.990165785742547*^9}, {3.9901659253126583`*^9, 
   3.990165940170278*^9}, {3.990166001395808*^9, 3.990166001889328*^9}, {
   3.9903722798522243`*^9, 3.990372290720393*^9}, {3.9903724085261497`*^9, 
   3.9903724159121437`*^9}, {3.990372459196888*^9, 3.990372468113405*^9}, {
   3.990374575740583*^9, 3.990374577578116*^9}},
 CellID->1460076169,ExpressionUUID->"09d24699-a28f-4542-8958-4816e5a184a2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"demoHtml", " ", "=", " ", 
   RowBox[{
    RowBox[{"XMLTemplate", "[", "demoTemplate", "]"}], "[", 
    RowBox[{"<|", "\[IndentingNewLine]", 
     RowBox[{"\"\<content\>\"", " ", "->", " ", 
      RowBox[{"ToWebGraphics", "[", 
       RowBox[{
        RowBox[{"Plot", "[", 
         RowBox[{"x", ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", " ", 
        RowBox[{"\"\<IncludeRuntime\>\"", " ", "->", " ", "False"}]}], 
       "]"}]}], "\[IndentingNewLine]", "|>"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9903744948084373`*^9, 3.990374550698463*^9}, {
  3.990374581583399*^9, 3.990374585696871*^9}},
 CellLabel->"In[147]:=",
 CellID->77622959,ExpressionUUID->"79a65157-d918-405f-82c1-4590e74234f1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A simple web server can be used to server these files;", "MathCaption",
 CellChangeTimes->{{3.990151586173532*^9, 3.990151588436767*^9}, {
   3.990152282911744*^9, 3.990152282983045*^9}, 3.9901523761018333`*^9, {
   3.990152410605566*^9, 3.990152412260754*^9}, {3.990152545129881*^9, 
   3.9901525723774147`*^9}, {3.990152608996687*^9, 3.990152693275676*^9}, {
   3.9901529891412687`*^9, 3.9901530609782457`*^9}, {3.9901534620624104`*^9, 
   3.990153473116312*^9}, {3.990153937396216*^9, 3.990153977018464*^9}, {
   3.990165733682437*^9, 3.990165785742547*^9}, {3.9901659253126583`*^9, 
   3.990165940170278*^9}, {3.990166001395808*^9, 3.990166001889328*^9}, {
   3.9903722798522243`*^9, 3.990372290720393*^9}, {3.9903724085261497`*^9, 
   3.9903724159121437`*^9}, {3.990372459196888*^9, 3.990372468113405*^9}, {
   3.990374575740583*^9, 3.9903746001532288`*^9}},
 CellID->104340878,ExpressionUUID->"842cc531-e5b6-491b-83cf-e18869e7ad5d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"runtimeMime", "[", "f_", "]"}], " ", ":=", " ", 
   RowBox[{"Switch", "[", 
    RowBox[{
     RowBox[{"ToLowerCase", " ", "@", " ", 
      RowBox[{"FileExtension", "[", "f", "]"}]}], ",", "\n", 
     "\t", "\"\<js\>\"", ",", "  ", "\"\<text/javascript\>\"", ",", "\n", 
     "\t", "\"\<css\>\"", ",", " ", "\"\<text/css\>\"", ",", "\n", "\t", "_", 
     ",", "     ", "\"\<application/octet-stream\>\""}], "\n", "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"disp", " ", "=", " ", 
   RowBox[{"URLDispatcher", "[", "\n", "\t", 

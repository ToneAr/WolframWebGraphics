   3.990370947859413*^9}, {3.990371031725108*^9, 3.990371041813048*^9}},
 CellID->668740853,ExpressionUUID->"9b7c737a-7a90-4eef-8b00-ab95b22a2a82"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"FileNames", "[", 
   RowBox[{"All", ",", "  ", "dir"}], "]"}], " ", "//", "Column"}]], "Input",
 CellChangeTimes->{{3.990371043814885*^9, 3.990371053188559*^9}, {
  3.99037109919733*^9, 3.990371111114109*^9}, {3.990371144264627*^9, 

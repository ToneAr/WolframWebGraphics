Cell["\<\
By default, WebGraphics will render with the LightDarkSwitched colours \
denoted by AbsoluteCurrentValue[LightDark]:\
\>", "ExampleText",
 CellChangeTimes->{{3.9900668165841722`*^9, 3.9900668715579147`*^9}},
 CellID->1968752503,ExpressionUUID->"84cf5415-d517-4799-bf43-3ed2b90b3138"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"\"\<Global Mode: \>\"", " ", "<>", " ", 
    RowBox[{"AbsoluteCurrentValue", "[", "LightDark", "]"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ToWebGraphics", "[", "\[IndentingNewLine]", 
     RowBox[{"Graphics", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"LightDarkSwitched", "[", 
         RowBox[{"Red", ",", "Blue"}], "]"}], ",", " ", 
        RowBox[{"Disk", "[", "]"}]}], "}"}], "]"}], "\[IndentingNewLine]", 
     "]"}], " ", "//", " ", 
    RowBox[{"StringCases", "[", 
     RowBox[{
      RowBox[{"Shortest", "[", 
       RowBox[{"\"\<fill='\>\"", "~~", "c__", "~~", "\"\<'\>\""}], "]"}], ":>",
       " ", 
      RowBox[{"RGBColor", "[", "c", "]"}]}], "]"}]}]}], "\[IndentingNewLine]",
   "}"}]], "Input",
